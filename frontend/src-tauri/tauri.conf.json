{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:3001",
    "distDir": "../out"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Chat App",
        "width": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "package": {
    "productName": "Chat App",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
        "dialog":{
            "all": true
        },
        "notification": {
            "all": true
        },
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "http": {
        "all": true,
        "scope": ["http://*", "https://*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.chatapp.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    }
  }
}
