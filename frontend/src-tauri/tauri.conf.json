{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:3000",
    "distDir": "../out"
  },
    "package": {
        "productName": "Spyke",
        "version": "0.1.1"
    },
    "tauri": {
      "windows": [
        {
          "fullscreen": false,
          "height": 600,
          "resizable": true,
          "title": "Spyke",
          "width": 800
        }
      ],
    "security": {
    "csp": null
    },
    "allowlist": {
        "dialog":{
            "all": true
        },
        "notification": {
            "all": true
        },
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "http": {
        "all": true,
        "scope": ["http://*", "https://*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.spyke.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
